{
  "name": "scoreboard",
  "version": "1.3.0",
  "description": "运动记分器",
  "main": "main.js",
  "scripts": {
    "test": "vitest run",
    "start": "electron .",
    "build": "electron-builder --mac",
    "prepare:mobile": "node scripts/prepare-mobile-web.mjs",
    "android:add": "npx cap add android",
    "ios:add": "npx cap add ios",
    "cap:sync": "npm run prepare:mobile && npx cap sync",
    "cap:sync:android": "npm run prepare:mobile && npx cap sync android",
    "cap:sync:ios": "npm run prepare:mobile && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "build:ios": "npm run assets:ios && npm run cap:sync:ios && npm run ios:open",
    "build:dmg": "electron-builder --mac dmg",
    "assets:android": "npx @capacitor/assets generate --android --assetPath assets --iconBackgroundColor '#0D2F6D' --splashBackgroundColor '#0D2F6D'",
    "assets:ios": "npx @capacitor/assets generate --ios --assetPath assets --iconBackgroundColor '#0D2F6D' --splashBackgroundColor '#0D2F6D'",
    "build:apk": "npm run assets:android && npm run cap:sync:android && cd android && ./gradlew assembleDebug",
    "build:apk:release": "npm run assets:android && npm run cap:sync:android && cd android && ./gradlew assembleRelease",
    "build:aab": "npm run assets:android && npm run cap:sync:android && cd android && ./gradlew bundleRelease"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.scoreboard.app",
    "productName": "记分器",
    "icon": "assets/app-icon.png",
    "files": [
      "index.html",
      "main.js",
      "manifest.json",
      "sw.js",
      "icons/**/*",
      "themes/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.sports",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.0"
  }
}
